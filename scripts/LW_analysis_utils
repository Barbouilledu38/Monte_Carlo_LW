        Altitudes = Altitudes[Altitudes > self.pos_camera[2]] - self.pos_camera[2]

        sigma = 5.67*10**(-8)
        plt.plot(sigma*Temperatures**4,Altitudes,'r')
        
        cax = ax.scatter(sigma*Temperatures**4,Altitudes, s = 0.5,c = 'blue', \
                         vmin = vmin, vmax= vmax, \
                         marker = 'o', label = 'SB')       
        
